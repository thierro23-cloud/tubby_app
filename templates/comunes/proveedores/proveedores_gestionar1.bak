<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🧩 Proveedores UltraCompacto</title>
    
    <!-- {# CDN MÍNIMOS #} -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    
    <style>
        /* {# ULTRACOMPACTO - Sin scroll garantizado #} */
        :root {
            --grad-primary: linear-gradient(135deg, #4f46e5, #7c3aed);
            --glass: rgba(255,255,255,0.9);
            --shadow: 0 4px 12px rgba(0,0,0,0.15);
            --radius: 12px;
        }
        
        * { font-family: system-ui, -apple-system, sans-serif; font-size: 0.8rem !important; }
        body {
            background: linear-gradient(145deg, #f1f5f9, #e2e8f0);
            margin: 0;
            padding: 0.5rem;
            height: 100vh;
            overflow: hidden;
        }
        
        /* {# HEADER ULTRAFINO #} */
        .header-compact {
            background: var(--grad-primary);
            color: white;
            padding: 0.5rem 0.75rem;
            border-radius: var(--radius) var(--radius) 0 0;
            box-shadow: var(--shadow);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-shrink: 0;
        }
        
        /* {# MAIN 100% HEIGHT #} */
        .main-compact {
            height: calc(100vh - 70px);
            display: flex;
            gap: 0.5rem;
            padding: 0.75rem;
            overflow: hidden;
        }
        
        /* {# IZQUIERDA 25% - Búsqueda #} */
        .left-panel {
            width: 25%;
            background: var(--glass);
            border-radius: var(--radius);
            padding: 0.75rem;
            box-shadow: var(--shadow);
            height: 100%;
            overflow: hidden;
        }
        
        /* {# DERECHA 75% - Formulario #} */
        .right-panel {
            width: 75%;
            background: var(--glass);
            border-radius: var(--radius);
            padding: 0.75rem;
            box-shadow: var(--shadow);
            height: 100%;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }
        
        /* {# SECCIONES ENMARCADAS - Hover scale #} */
        .section-frame {
            background: white;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            padding: 0.5rem;
            margin-bottom: 0.25rem;
            transition: all 0.2s ease;
            cursor: pointer;
            height: 80px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        
        .section-frame:hover {
            border-color: #6366f1;
            transform: scale(1.02);
            box-shadow: 0 6px 20px rgba(99,102,241,0.3);
            z-index: 10;
        }
        
        .section-title {
            font-size: 0.7rem !important;
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.25rem;
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }
        
        /* {# INPUTS ULTRAPEQUEÑOS #} */
        .input-tiny {
            padding: 0.25rem 0.4rem !important;
            height: 28px !important;
            font-size: 0.7rem !important;
            border: 1px solid #d1d5db;
            border-radius: 4px;
        }
        
        .input-tiny:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 0.05rem rgba(99,102,241,0.2);
        }
        
        .select-tiny {
            padding: 0.25rem 0.4rem !important;
            height: 28px !important;
            font-size: 0.7rem !important;
        }
        
        /* {# SWITCHS MINI #} */
        .switch-mini .form-check-input {
            width: 32px;
            height: 20px;
        }
        .switch-mini .form-check-input:checked {
            background-color: #10b981;
            border-color: #10b981;
        }
        
        /* {# BOTONES MICRO #} */
        .btn-micro {
            padding: 0.25rem 0.5rem !important;
            font-size: 0.65rem !important;
            height: 26px;
            border-radius: 4px;
        }
        
        /* {# TABS DE TIPOS - Agrupación #} */
        .type-tab {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 0.25rem 0.5rem;
            border-radius: 20px;
            font-size: 0.6rem !important;
            font-weight: 500;
            margin-right: 0.25rem;
            transition: all 0.2s;
        }
        
        .type-tab.active {
            background: var(--grad-primary);
            color: white;
        }
    </style>
</head>
<body>
    <!-- {# HEADER ULTRACOMPACTO #} -->
    <div class="header-compact">
        <div class="d-flex align-items-center gap-1">
            <i class="bi bi-building-gear fs-5"></i>
            <span class="fw-bold">Proveedores</span>
        </div>
        <div class="d-flex gap-1">
            <button class="btn btn-light btn-micro" onclick="limpiarTodo()" title="Nuevo">
                <i class="bi bi-plus"></i>
            </button>
            <button type="submit" form="formMain" class="btn btn-light btn-micro" title="Guardar">
                <i class="bi bi-check"></i>
            </button>
        </div>
    </div>
    
    <!-- {# MAIN SPLIT 25/75 - ALTURA EXACTA #} -->
    <div class="main-compact">
        <!-- {# IZQUIERDA: BÚSQUEDA + RESUMEN #} -->
        <div class="left-panel">
            <!-- Búsqueda -->
            <div class="section-frame mb-2">
                <div class="section-title">
                    <i class="bi bi-search"></i> Buscar
                </div>
                <input type="text" class="input-tiny w-100 mb-1" id="buscarNIF" placeholder="NIF">
                <input type="text" class="input-tiny w-100" id="buscarNom" placeholder="Nombre">
            </div>
            
            <!-- Resumen -->
            <div class="section-frame">
                <div class="section-title">
                    <i class="bi bi-file-text"></i> Resumen
                </div>
                <div class="small">
                    <div>ID: <span id="resID" class="fw-bold">-</span></div>
                    <div>NIF: <span id="resNIF">-</span></div>
                    <div><span id="resStatus" class="type-tab">Nuevo</span></div>
                </div>
            </div>
        </div>
        
        <!-- {# DERECHA: FORMULARIO POR TIPOS #} -->
        <div class="right-panel">
            <form id="formMain" method="POST">
                <input type="hidden" id="idProv" name="Idtbl_proveedores">
                
                <!-- {# TABS TIPOS - Agrupación visual #} -->
                <div class="d-flex flex-wrap gap-1 mb-2 pb-1" style="border-bottom: 1px solid #e2e8f0;">
                    <span class="type-tab active" onclick="mostrarTipo('basico')">Básico</span>
                    <span class="type-tab" onclick="mostrarTipo('direccion')">Dirección</span>
                    <span class="type-tab" onclick="mostrarTipo('contacto')">Contactos</span>
                    <span class="type-tab" onclick="mostrarTipo('banco')">Bancos</span>
                    <span class="type-tab" onclick="mostrarTipo('caract')">Características</span>
                </div>
                
                <!-- {# TIPO 1: BÁSICO #} -->
                <div id="secBasico" class="tipo-section active">
                    <div class="section-frame">
                        <div class="section-title">
                            <i class="bi bi-person"></i> Datos Empresa
                        </div>
                        <div class="row g-1">
                            <div class="col-6"><input class="input-tiny w-100" name="NIF" required placeholder="NIF"></div>
                            <div class="col-6"><input class="input-tiny w-100" name="Nombre_Razon_Social" required placeholder="Razón Social"></div>
                            <div class="col-6"><input class="input-tiny w-100" name="Telefono" placeholder="Teléfono"></div>
                            <div class="col-6"><input class="input-tiny w-100" name="ALIAS" placeholder="Alias"></div>
                        </div>
                    </div>
                </div>
                
                <!-- {# TIPO 2: DIRECCIÓN #} -->
                <div id="secDireccion" class="tipo-section">
                    <div class="section-frame">
                        <div class="section-title">
                            <i class="bi bi-geo"></i> Dirección
                        </div>
                        <div class="row g-1">
                            <div class="col-3">
                                <select class="select-tiny w-100" name="idtbl_provincias" onchange="cargaMun(this.value)">
                                    <option>Prov</option>
                                </select>
                            </div>
                            <div class="col-3">
                                <select class="select-tiny w-100" name="idtbl_municipios" disabled>
                                    <option>Mun</option>
                                </select>
                            </div>
                            <div class="col-3">
                                <select class="select-tiny w-100" name="idtbl_tipos_de_vias">
                                    <option>Vía</option>
                                </select>
                            </div>
                            <div class="col-3">
                                <select class="select-tiny w-100" name="idtbl_calles" disabled>
                                    <option>Calle</option>
                                </select>
                            </div>
                        </div>
                        <input class="input-tiny w-100 mt-1" name="Domicilio" placeholder="Domicilio">
                    </div>
                </div>
                
                <!-- {# TIPO 3: CONTACTOS #} -->
                <div id="secContacto" class="tipo-section">
                    <div class="section-frame">
                        <div class="section-title">
                            <i class="bi bi-telephone"></i> Contactos
                        </div>
                        <div class="row g-1">
                            <div class="col-6"><input class="input-tiny w-100" name="Persona_contacto_comercial" placeholder="Comercial"></div>
                            <div class="col-6"><input class="input-tiny w-100" name="telefono_movil" placeholder="Móvil"></div>
                            <div class="col-6"><input class="input-tiny w-100" name="Persona_contacto_admin" placeholder="Admin"></div>
                            <div class="col-6"><input class="input-tiny w-100" name="telefono_fijo_admin" placeholder="Fijo"></div>
                        </div>
                    </div>
                </div>
                
                <!-- {# TIPO 4: BANCOS #} -->
                <div id="secBanco" class="tipo-section">
                    <div class="section-frame">
                        <div class="section-title">
                            <i class="bi bi-bank"></i> Bancos
                        </div>
                        <div class="row g-1">
                            <div class="col-6"><input class="input-tiny w-100" name="numero_cuenta" placeholder="Cuenta"></div>
                            <div class="col-3"><select class="select-tiny w-100" name="idtbl_Tipo_de_Tercero"><option>Tipo</option></select></div>
                            <div class="col-3"><select class="select-tiny w-100" name="idtbl_productos_grupos"><option>Grupo</option></select></div>
                        </div>
                    </div>
                </div>
                
                <!-- {# TIPO 5: CARACTERÍSTICAS #} -->
                <div id="secCaract" class="tipo-section">
                    <div class="section-frame">
                        <div class="section-title">
                            <i class="bi bi-check-all"></i> Flags
                        </div>
                        <div class="d-flex flex-wrap gap-1 small">
                            <div class="switch-mini form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="parquin" id="p1">
                                <label class="form-check-label" for="p1">Parq</label>
                            </div>
                            <div class="switch-mini form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="es_bar" id="p2">
                                <label class="form-check-label" for="p2">Bar</label>
                            </div>
                            <div class="switch-mini form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="empresa_construccion" id="p3">
                                <label class="form-check-label" for="p3">Const</label>
                            </div>
                            <div class="switch-mini form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="recibir_informe_pendientes" id="p4">
                                <label class="form-check-label" for="p4">Info</label>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- {# JS ULTRAOPTIMIZADO #} -->
    <script>
        /* {# ANTI-SCROLL GARANTIZADO #} */
        document.body.style.overflow = 'hidden';
        
        /* {# TABS TIPOS #} */
        function mostrarTipo(tipo) {
            document.querySelectorAll('.tipo-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.type-tab').forEach(t => t.classList.remove('active'));
            document.getElementById(`sec${tipo.charAt(0).toUpperCase() + tipo.slice(1)}`).classList.add('active');
            event.target.classList.add('active');
        }
        
        /* {# BÚSQUEDA DEBOUNCE #} */
        let timer;
        ['buscarNIF','buscarNom'].forEach(id => {
            document.getElementById(id).oninput = () => {
                clearTimeout(timer);
                timer = setTimeout(() => buscarProveedor(id), 250);
            };
        });
        
        async function buscarProveedor(id) {
            const valor = document.getElementById(id).value;
            if (valor.length < 2) return;
            
            const tipo = id === 'buscarNIF' ? 'nif' : 'nombre';
            try {
                const res = await fetch(`/comunes/proveedores/api/buscar_por_${tipo}?texto=${valor}`);
                const data = await res.json();
                if (data.success) {
                    window.location.href = `/comunes/proveedores/formulario?prov_id=${data.prov_id}`;
                }
            } catch(e) {}
        }
        
        /* {# COMBOS MÍNIMOS #} */
        async function cargaMun(provId) {
            if (!provId) return;
            const res = await fetch(`/comunes/proveedores/api/municipios?prov_id=${provId}`);
            const opts = await res.json();
            const sel = document.querySelector('[name="idtbl_municipios"]');
            sel.innerHTML = '<option>Mun</option>' + opts.map(o => `<option value="${o.id}">${o.nombre}</option>`).join('');
        }
        
        /* {# LIMPIAR TODO #} */
        function limpiarTodo() {
            document.getElementById('formMain').reset();
            document.getElementById('idProv').value = '';
            document.getElementById('resStatus').textContent = 'Nuevo';
        }
        
        /* {# LOAD INICIAL #} */
        window.onload = () => {
            // Cargar provincias mínimas
            fetch('/comunes/proveedores/api/provincias').then(r => r.json()).then(data => {
                const sel = document.querySelector('[name="idtbl_provincias"]');
                sel.innerHTML = '<option>Prov</option>' + data.map(d => `<option value="${d.id}">${d.nombre}</option>`).join('');
            });
        };
    </script>
</body>
</html>