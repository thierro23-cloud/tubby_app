# =============================================================================
# 1️⃣ INTRODUCCIÓN · WATCHER DE PDFs DE CONTENEDORES
# =============================================================================
# Este módulo implementa:
#
#   1.1) Rutas robustas para la gestión de contenedores:
#         - entrada_pdf/
#         - papelera/
#         - para_revision/
#         - pendientes_validacion/
#
#   1.2) Un watcher basado en watchdog que detecta nuevos PDFs en
#        entrada_pdf/ y lanza la lógica de procesado.
#
#   1.3) Un mecanismo simple para evitar iniciar el watcher más de una
#        vez por proceso (watcher_activo).
#
# OBJETIVO:
#   - Que el watcher funcione igual en local y en servidor, siempre que
#     se mantenga la misma estructura relativa de carpetas.
#
# 🏭 PASO A SERVIDOR (PRODUCCIÓN):
#   - El módulo calcula BASE_DIR como la raíz del proyecto:
#         tubby_app/
#             app.py
#             watchers/
#             contenedores/
#                 entrada_pdf/
#                 papelera/
#                 para_revision/
#                 pendientes_validacion/
#
#   - Para desplegar en un servidor, basta con:
#         1) Copiar esta misma estructura en una ruta fija
#            (ejemplo: /opt/tubby_app).
#         2) Crear, si no existen, las carpetas:
#               contenedores/entrada_pdf
#               contenedores/papelera
#               contenedores/para_revision
#               contenedores/pendientes_validacion
#         3) Arrancar la app desde la raíz del proyecto con un
#            servidor WSGI (ejemplo):
#               gunicorn -w 3 "app:app"
#
#   - NO es necesario modificar rutas ni código del watcher entre
#     entorno local y servidor.
# =============================================================================

import os

from watchdog.observers import Observer
from watchdog.events import PatternMatchingEventHandler

from flask import current_app

from watchers.utils_async import procesar_pdf_entrada


# =============================================================================
# 2️⃣ RUTAS DE CARPETAS DE CONTENEDORES
# =============================================================================
# 2.1) BASE_DIR Y CARPETAS DE TRABAJO (COMIENZA)
# -----------------------------------------------------------------------------
# BASE_DIR se calcula como la raíz del proyecto "tubby_app" de forma
# relativa a este fichero:
#
#   tubby_app/
#       app.py
#       watchers/
#           contenedores_watcher.py  <-- aquí
#       contenedores/
#           entrada_pdf/
#           papeleras/
#           para_revision/
#           pendientes_validacion/
#
# En el servidor, bastará con colocar el proyecto en una ruta tipo:
#   /opt/tubby_app/...
# con la misma estructura interna.
# -----------------------------------------------------------------------------
BASE_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))

CARPETA_CONTENEDORES = os.path.join(BASE_DIR, "contenedores")
CARPETA_ENTRADA = os.path.join(CARPETA_CONTENEDORES, "entrada_pdf")
CARPETA_PAPELERA = os.path.join(CARPETA_CONTENEDORES, "papelera")
CARPETA_REVISION = os.path.join(CARPETA_CONTENEDORES, "para_revision")
CARPETA_PENDIENTES = os.path.join(CARPETA_CONTENEDORES, "pendientes_validacion")
# 2.1) BASE_DIR Y CARPETAS DE TRABAJO (TERMINA)
# -----------------------------------------------------------------------------


# =============================================================================
# 3️⃣ ESTADO DEL WATCHER · VARIABLES DE MÓDULO
# =============================================================================
# 3.1) BANDERAS DE CONTROL (COMIENZA)
# -----------------------------------------------------------------------------
# watcher_activo:
#   - Indica si el watcher ya ha sido iniciado en este proceso.
#
# observer:
#   - Instancia de watchdog.Observer controlada desde este módulo.
# -----------------------------------------------------------------------------
watcher_activo = False
observer = None
# 3.1) BANDERAS DE CONTROL (TERMINA)
# -----------------------------------------------------------------------------


# =============================================================================
# 4️⃣ HANDLER DE EVENTOS · PatternMatchingEventHandler
# =============================================================================
# 4.1) ContenedoresHandler (COMIENZA)
# -----------------------------------------------------------------------------
# Este handler:
#   - Escucha solo archivos *.pdf (ignore_directories=True).
#   - En cada archivo creado:
#       · Entra en contexto de app.
#       · Loguea la detección.
#       · Llama a utils_async.procesar_pdf_entrada(nombre_pdf), que:
#             - Llama al backend industrial (procesar_pdf_core).
#             - Decide si se auto‑guarda o se crea pendiente.
#             - Mueve el PDF a:
#                   · papelera          (si auto_guardado)
#                   · para_revision     (si pendiente_validacion)
#             - Inserta/actualiza tbl_contenedores_pendientes según el caso.
#
# NOTA:
#   - Aquí ya no se hace lógica de negocio ni se toca la BD directamente;
#     todo eso está encapsulado en utils_async + backend de contenedores.
# -----------------------------------------------------------------------------
class ContenedoresHandler(PatternMatchingEventHandler):
    def __init__(self, app):
        super().__init__(patterns=["*.pdf"], ignore_directories=True)
        self.app = app

    def on_created(self, event):
        if event.is_directory:
            return

        ruta_pdf = event.src_path
        nombre_pdf = os.path.basename(ruta_pdf)

        # Log inmediato de detección (no bloquea)
        with self.app.app_context():
            self.app.logger.info(f"[WATCHER] PDF detectado en entrada_pdf: {ruta_pdf}")

            # Delegamos todo el procesado en utils_async
            resultado = procesar_pdf_entrada(nombre_pdf)

            self.app.logger.info(
                "[WATCHER] Resultado procesar_pdf_entrada -> "
                f"estado={resultado.get('estado')} "
                f"motivo={resultado.get('motivo')} "
                f"id_pendiente={resultado.get('id_pendiente')} "
                f"ruta_final_pdf={resultado.get('ruta_final_pdf')}"
            )
# 4.1) ContenedoresHandler (TERMINA)
# -----------------------------------------------------------------------------


# =============================================================================
# 5️⃣ INICIAR WATCHER DE CONTENEDORES
# =============================================================================
# 5.1) iniciar_watcher_contenedores(app) (COMIENZA)
# -----------------------------------------------------------------------------
# Arranca el watcher de contenedores si aún no está activo:
#
#   - Crea las carpetas de trabajo si no existen:
#         · entrada_pdf
#         · papelera
#         · para_revision
#         · pendientes_validacion
#   - Crea el Observer de watchdog.
#   - Lo asocia al handler ContenedoresHandler.
#   - Lo arranca en segundo plano.
#
# La bandera watcher_activo evita que se inicie dos veces en el mismo
# proceso (por ejemplo, si la factory se llama más de una vez).
# -----------------------------------------------------------------------------
def iniciar_watcher_contenedores(app):
    global watcher_activo, observer

    if watcher_activo:
        app.logger.info("ℹ Watcher de contenedores ya estaba activo; no se reinicia")
        return

    # Asegurarnos de que las carpetas existen
    os.makedirs(CARPETA_ENTRADA, exist_ok=True)
    os.makedirs(CARPETA_PAPELERA, exist_ok=True)
    os.makedirs(CARPETA_REVISION, exist_ok=True)
    os.makedirs(CARPETA_PENDIENTES, exist_ok=True)

    handler = ContenedoresHandler(app)
    observer = Observer()
    observer.schedule(handler, path=CARPETA_ENTRADA, recursive=False)
    observer.start()

    watcher_activo = True
    app.logger.info(f"🚀 Watcher iniciado: {CARPETA_ENTRADA}")
    app.logger.info(f"👁 [entrada_pdf] Vigilando carpeta: {CARPETA_ENTRADA}")
# 5.1) iniciar_watcher_contenedores(app) (TERMINA)
# -----------------------------------------------------------------------------


# =============================================================================
# 6️⃣ FIN · watchers/contenedores_watcher.py
# =============================================================================