# 8️⃣ BANDEJA INICIAL · IMPLEMENTACIÓN REAL
# =============================================================================

def _extraer_texto_general(ruta_pdf: str) -> str:
    """
    Extrae el texto de un PDF para clasificación general de vía pública.

    Usa PyPDF2 en modo sencillo: concatena páginas y devuelve una cadena.
    Se limpia saltos de línea y tabuladores para facilitar búsquedas.

    Si falla la extracción, devuelve cadena vacía y deja trazas en log.
    """
    try:
        texto = ""
        with open(ruta_pdf, "rb") as f:
            reader = PyPDF2.PdfReader(f)
            for page in reader.pages:
                texto += page.extract_text() or ""
        return texto.replace("\n", " ").replace("\t", " ")
    except Exception as e:
        current_app.logger.error(
            f"[UTILS_ASYNC_INICIAL] Error extrayendo texto de {ruta_pdf}: {e!r}"
        )
        return ""


def _clasificar_tipo_general(texto: str) -> str:
    """
    Determina el tipo de expediente municipal a partir del texto del PDF.

    Reglas orientadas a documentación real de Ávila:
      - CONTENEDORES:
          · menciones a 'contenedor', 'contenedores', 'ocupación temporal',
            'residuos', formularios de colocación/retirada de contenedores.
      - OBRAS:
          · 'licencia de obras', 'obras', 'proyecto técnico', 'permiso de obras',
            'dominio público local motivado por las obras' [web:58].
      - TERRAZAS:
          · 'instalación de terraza', 'terrazas en la vía pública',
            'ordenanza reguladora de la instalación de terrazas' [web:59][web:62].
      - VADOS:
          · 'licencia municipal de vado', 'vado permanente', 'acceso al local',
            'tasa por utilización privativa del dominio público' [web:60].
      - OTROS:
          · cualquier texto que no encaje en los patrones anteriores.
    """
    t = texto.upper()

    # CONTENEDORES
    if (
        "CONTENEDOR" in t
        or "CONTENEDORES" in t
        or "RESIDUOS" in t
        or "OCUPACIÓN TEMPORAL" in t
    ):
        return "contenedores"

    # OBRAS
    if (
        "LICENCIA DE OBRAS" in t
        or "OBRAS" in t
        or "PROYECTO TÉCNICO" in t
        or "DOMINIO PÚBLICO LOCAL MOTIVADO POR LAS OBRAS" in t
    ):
        return "obras"

    # TERRAZAS
    if (
        "INSTALACIÓN DE TERRAZA" in t
        or "INSTALACIÓN DE TERRAZAS" in t
        or "TERRAZAS EN LA VÍA PÚBLICA" in t
        or "ORDENANZA REGULADORA DE LA INSTALACIÓN DE TERRAZAS" in t
    ):
        return "terrazas"

    # VADOS
    if (
        "LICENCIA MUNICIPAL DE VADO" in t
        or "VADO PERMANENTE" in t
        or "VADO PROVISIONAL" in t
        or "ACCESO AL LOCAL" in t
        or "TASA POR UTILIZACIÓN PRIVATIVA" in t
    ):
        return "vados"

    return "otros"


def procesar_pdf_inicial(nombre_pdf: str) -> dict:
    """
    BANDEJA INICIAL · CLASIFICACIÓN GENERAL DE PDFs DE VÍA PÚBLICA (ÁVILA)

    Flujo:
      1) Ubica el PDF en carpeta_inicial_pdf.
      2) Extrae texto con PyPDF2.
      3) Clasifica el tipo de expediente (contenedores / obras / terrazas / vados / otros).
      4) Determina la carpeta entrada_pdf correspondiente.
      5) Mueve el PDF desde carpeta_inicial_pdf a esa entrada_pdf.
      6) Delegar en la función específica del módulo (si existe) o devolver estado.

    Devuelve:
      - estado: "ok" si se ha movido correctamente, otro valor en caso de error.
      - motivo: explicativo.
      - tipo: tipo de expediente detectado.
      - ruta_final_pdf: ruta absoluta donde acaba el PDF.
      - ruta_csv: None (por ahora la bandeja inicial no genera CSV).
    """
    # 1) Carpeta inicial física (bandeja general).
    base_proyecto = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    carpeta_inicial = os.path.join(base_proyecto, "carpeta_inicial_pdf")
    ruta_inicial = os.path.join(carpeta_inicial, nombre_pdf)

    current_app.logger.info(
        f"[UTILS_ASYNC_INICIAL] procesar_pdf_inicial: inicio con '{nombre_pdf}'"
    )

    if not os.path.exists(ruta_inicial):
        motivo = "PDF no encontrado en carpeta_inicial_pdf"
        current_app.logger.error(
            f"[UTILS_ASYNC_INICIAL] {motivo}: {ruta_inicial}"
        )
        return {
            "estado": "error",
            "motivo": motivo,
            "tipo": None,
            "ruta_final_pdf": None,
            "ruta_csv": None,
        }

    # 2) Extraer texto del PDF.
    texto = _extraer_texto_general(ruta_inicial)

    # 3) Clasificar tipo de expediente.
    tipo = _clasificar_tipo_general(texto)

    current_app.logger.info(
        f"[UTILS_ASYNC_INICIAL] PDF {nombre_pdf} clasificado como tipo='{tipo}'"
    )

    # 4) Asegurar carpetas destino por tipo.
    if tipo == "contenedores":
        _ensure_contenedores_dirs()
        carpeta_destino = _ruta_pdf("entrada_pdf", "")
    elif tipo == "obras":
        _ensure_obras_dirs()
        carpeta_destino = _ruta_pdf_obras("entrada_pdf", "")
    elif tipo == "terrazas":
        _ensure_terrazas_dirs()
        carpeta_destino = _ruta_pdf_terrazas("entrada_pdf", "")
    elif tipo == "vados":
        _ensure_vados_dirs()
        carpeta_destino = _ruta_pdf_vados("entrada_pdf", "")
    else:
        _ensure_otros_dirs()
        carpeta_destino = _ruta_pdf_otros("entrada_pdf", "")

    # Quitar el nombre vacío y construir ruta destino completa.
    carpeta_destino_real = os.path.dirname(carpeta_destino)
    ruta_final_pdf = os.path.join(carpeta_destino_real, nombre_pdf)

    # 5) Mover el PDF.
    try:
        shutil.move(ruta_inicial, ruta_final_pdf)
        current_app.logger.info(
            f"[UTILS_ASYNC_INICIAL] PDF movido a {ruta_final_pdf}"
        )
    except Exception as e:
        current_app.logger.error(
            f"[UTILS_ASYNC_INICIAL] Error moviendo PDF a destino ({tipo}): {e!r}"
        )
        return {
            "estado": "error",
            "motivo": "Error moviendo PDF a carpeta destino",
            "tipo": tipo,
            "ruta_final_pdf": ruta_inicial,
            "ruta_csv": None,
        }

    # 6) Delegar en función específica de módulo (cuando exista).
    try:
        if tipo == "contenedores":
            resultado_modulo = procesar_pdf_entrada(nombre_pdf)
            # Respetamos el resultado del módulo pero añadimos tipo.
            resultado_modulo.setdefault("tipo", tipo)
            return resultado_modulo

        if tipo == "obras":
            resultado_modulo = procesar_pdf_entrada_obras(nombre_pdf)
            resultado_modulo.setdefault("tipo", tipo)
            return resultado_modulo

        if tipo == "terrazas":
            # Cuando implementes procesar_pdf_entrada_terrazas, llama aquí:
            # resultado_modulo = procesar_pdf_entrada_terrazas(nombre_pdf)
            # resultado_modulo.setdefault("tipo", tipo)
            # return resultado_modulo
            current_app.logger.info(
                "[UTILS_ASYNC_INICIAL] Tipo terrazas detectado, pero backend de terrazas no está implementado aún."
            )

        if tipo == "vados":
            # Cuando tengas backend de vados:
            # resultado_modulo = procesar_pdf_entrada_vados(nombre_pdf)
            # resultado_modulo.setdefault("tipo", tipo)
            # return resultado_modulo
            current_app.logger.info(
                "[UTILS_ASYNC_INICIAL] Tipo vados detectado, pero backend de vados no está implementado aún."
            )

    except Exception as e:
        current_app.logger.error(
            f"[UTILS_ASYNC_INICIAL] Error delegando en módulo {tipo}: {e!r}"
        )
        return {
            "estado": "error",
            "motivo": f"Error delegando en módulo {tipo}",
            "tipo": tipo,
            "ruta_final_pdf": ruta_final_pdf,
            "ruta_csv": None,
        }

    # Si no hay backend específico o todavía está en desarrollo,
    # devolvemos un resultado genérico.
    return {
        "estado": "ok",
        "motivo": "PDF movido a bandeja de entrada por tipo",
        "tipo": tipo,
        "ruta_final_pdf": ruta_final_pdf,
        "ruta_csv": None,
    }


