# =============================================================================
# 2️⃣ RUTAS DE CARPETAS · CONTENEDORES (RELATIVAS A root_path)
# =============================================================================


def _carpeta_contenedores_base() -> str:
    """
    Devuelve la carpeta base de contenedores dentro de la app:
      <root_path>/contenedores
    """
    return os.path.join(current_app.root_path, "contenedores")


def _ensure_contenedores_dirs() -> None:
    """
    Asegura que existen las subcarpetas de trabajo de contenedores:
      - entrada_pdf
      - para_revision
      - pendientes_validacion
      - solo_retirada
      - papelera
      - colocacion (auto_guardado)
    """
    base = _carpeta_contenedores_base()
    for sub in [
        "entrada_pdf",
        "para_revision",
        "pendientes_validacion",
        "solo_retirada",
        "papelera",
        "colocacion",
    ]:
        os.makedirs(os.path.join(base, sub), exist_ok=True)


def _ruta_pdf(subcarpeta: str, nombre_pdf: str) -> str:
    """
    Construye la ruta absoluta a un PDF de contenedores dado subcarpeta y nombre.
    """
    base = _carpeta_contenedores_base()
    return os.path.join(base, subcarpeta, nombre_pdf)


def _nombre_pdf_por_csv(csv_value: str | None, nombre_por_defecto: str) -> str:
    """
    Devuelve el nombre de archivo físico a partir de un CSV:
      - Si csv_value es None, devuelve nombre_por_defecto.
      - Si csv_value ya tiene '.', se respeta (posible extensión).
      - En caso contrario, se añade .pdf.
    """
    if not csv_value:
        return nombre_por_defecto
    if "." in csv_value:
        return csv_value
    return f"{csv_value}.pdf"
def emparejar_retiradas_con_colocaciones(id_usuario_logueado: int) -> dict:
    """
    EMPAREJAR RETIRADAS · tbl_contenedores_retirada → tbl_control_contenedores

    Criterios:
      - Coincidencia estricta de:
          · idtbl_proveedores,
          · idtbl_tipos_de_vias,
          · idtbl_calles.
      - fecha_colocacion <= fecha_retirada.
      - fecha_colocacion más próxima a fecha_retirada (mínimo ABS(DATEDIFF)),
        sin límite de diferencia en días.
      - Solo se emparejan colocaciones sin retirada:
          · fecha_retirada IS NULL,
          · csv_retirada IS NULL o vacío.

    Acciones:
      - Actualizar tbl_control_contenedores con datos de retirada:
          · csv_retirada,
          · fecha_retirada,
          · n_solicitud_retirada,
          · idtbl_gestor_retirada,
          · fecha_subida_retirada (NOW()).
      - Marcar tbl_contenedores_retirada:
          · tiene_relacion = 1,
          · idtbl_contenedor_colocacion = idtbl_control_contenedores,
          · fecha_validacion = NOW().
      - Borrar la fila de tbl_contenedores_retirada tras emparejar.

    Parámetros:
      - id_usuario_logueado: ID del usuario actual (gestor de retirada),
        que se grabará en idtbl_gestor_retirada en control. Es automático,
        no hay intervención humana manual en la elección.

    Retorno:
      - dict con resumen:
          · total_retiradas,
          · emparejadas,
          · sin_match.
    """
    current_app.logger.info(
        "[EMPAREJADOR_RET] Inicio emparejado retiradas → control_contenedores"
    )

    # 1) Seleccionar retiradas pendientes de relación.
    sql_select_retiradas = """
        SELECT
            idtbl_contenedores_retirada,
            idtbl_proveedores,
            idtbl_tipos_de_vias,
            idtbl_calles,
            fecha_retirada,
            csv_retirada,
            numero_solicitud
        FROM tbl_contenedores_retirada
        WHERE fecha_retirada IS NOT NULL
          AND idtbl_proveedores IS NOT NULL
          AND idtbl_tipos_de_vias IS NOT NULL
          AND idtbl_calles IS NOT NULL
          AND (tiene_relacion = 0 OR tiene_relacion IS NULL)
          AND (idtbl_contenedor_colocacion IS NULL OR idtbl_contenedor_colocacion = 0)
    """

    retiradas = ejecutar_query(
        sql_select_retiradas, (), nombre_bd="control_via_publica"
    )

    total_retiradas = len(retiradas)
    emparejadas = 0
    sin_match = 0

    for r in retiradas:
        id_retirada = r["idtbl_contenedores_retirada"]
        id_proveedor = r["idtbl_proveedores"]
        id_tipo_via = r["idtbl_tipos_de_vias"]
        id_calle = r["idtbl_calles"]
        fecha_retirada = r["fecha_retirada"]
        csv_retirada = r["csv_retirada"]
        numero_solicitud = r["numero_solicitud"]

        current_app.logger.info(
            f"[EMPAREJADOR_RET] Retirada {id_retirada}: "
            f"proveedor={id_proveedor}, tipo_via={id_tipo_via}, calle={id_calle}, "
            f"fecha_retirada={fecha_retirada}, csv_retirada={csv_retirada}, "
            f"numero_solicitud={numero_solicitud}"
        )

        # 2) Buscar colocación compatible en control_contenedores.
        #    Se busca la fecha de colocación más próxima, sin límite de diferencia.
        sql_buscar_colocacion = """
            SELECT
                idtbl_control_contenedores,
                fecha_colocacion,
                csv
            FROM tbl_control_contenedores
            WHERE idtbl_proveedores = %s
              AND idtbl_tipos_de_vias = %s
              AND idtbl_calles = %s
              AND fecha_colocacion <= %s
              AND (fecha_retirada IS NULL)
              AND (csv_retirada IS NULL OR csv_retirada = '')
            ORDER BY ABS(DATEDIFF(fecha_colocacion, %s)) ASC
            LIMIT 1
        """

        colocaciones = ejecutar_query(
            sql_buscar_colocacion,
            (id_proveedor, id_tipo_via, id_calle, fecha_retirada, fecha_retirada),
            nombre_bd="control_via_publica",
        )

        if not colocaciones:
            current_app.logger.warning(
                f"[EMPAREJADOR_RET] NO se encontró colocación compatible para retirada {id_retirada}"
            )
            sin_match += 1
            continue

        colocacion = colocaciones[0]
        id_control = colocacion["idtbl_control_contenedores"]
        fecha_colocacion = colocacion["fecha_colocacion"]
        csv_colocacion = colocacion["csv"]

        current_app.logger.info(
            f"[EMPAREJADOR_RET] Retirada {id_retirada} emparejada con control {id_control}: "
            f"fecha_colocacion={fecha_colocacion}, csv_colocacion={csv_colocacion}"
        )

        # 3) Actualizar control_contenedores con la retirada.
        sql_update_control = """
            UPDATE tbl_control_contenedores
            SET csv_retirada = %s,
                fecha_retirada = %s,
                n_solicitud_retirada = %s,
                idtbl_gestor_retirada = %s,
                fecha_subida_retirada = NOW()
            WHERE idtbl_control_contenedores = %s
        """

        ejecutar_non_query(
            sql_update_control,
            (csv_retirada, fecha_retirada, numero_solicitud, id_usuario_logueado, id_control),
            nombre_bd="control_via_publica",
        )

        # 4) Marcar retirada como emparejada.
        sql_update_retirada = """
            UPDATE tbl_contenedores_retirada
            SET tiene_relacion = 1,
                idtbl_contenedor_colocacion = %s,
                fecha_validacion = NOW()
            WHERE idtbl_contenedores_retirada = %s
        """

        ejecutar_non_query(
            sql_update_retirada,
            (id_control, id_retirada),
            nombre_bd="control_via_publica",
        )

        # 5) Borrar retirada consolidada (tal y como indicas).
        sql_delete_retirada = """
            DELETE FROM tbl_contenedores_retirada
            WHERE idtbl_contenedores_retirada = %s
        """
        ejecutar_non_query(
            sql_delete_retirada,
            (id_retirada,),
            nombre_bd="control_via_publica",
        )
        current_app.logger.info(
            f"[EMPAREJADOR_RET] Retirada {id_retirada} eliminada de tbl_contenedores_retirada tras emparejar."
        )

        emparejadas += 1

    resumen = {
        "total_retiradas": total_retiradas,
        "emparejadas": emparejadas,
        "sin_match": sin_match,
    }

    current_app.logger.info(
        f"[EMPAREJADOR_RET] Fin emparejado: {resumen}"
    )

    return resumen


