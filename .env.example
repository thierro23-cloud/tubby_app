# Environment Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# MySQL connection (shared by all databases)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your-db-password-here
DB_PORT=3306

# Database name overrides (optional — defaults shown below)
DB_BD_TBL_COMUNES_NAME=bd_tbl_comunes
DB_CONTROL_VIA_PUBLICA_NAME=control_via_publica
DB_GIS_MUNICIPAL_NAME=gis_municipal
DB_INVENTARIO_NAME=inventario
DB_MOBILIARIO_URBANO_NAME=mobiliario_urbano
DB_PARQUIN_CAMIONES_NAME=parquin_camiones
DB_PATRULLA_VERDE_NAME=patrulla_verde
DB_PERSONAL_VESTUARIO_NAME=personal_vestuario
DB_PLAN_DE_EMERGENCIAS_NAME=plan_de_emergencias
