# =============================================================================
# 🐳 TUBBY APP · .dockerignore
# =============================================================================
# Files/dirs excluded from the Docker build context.
# Keeps the image lean and prevents secrets from leaking into the image.

# Version control
.git
.gitignore

# Python artefacts
__pycache__
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
*.egg-info/
dist/
build/

# Environment / secrets  ← NEVER bake these into the image
.env
.env.*
!.env.example
!.env.docker.example

# Docker files (not needed inside the image)
Dockerfile*
docker-compose*.yml
.dockerignore

# Logs and runtime data
logs/
*.log

# Contenedores (mounted as a volume at runtime)
contenedores/

# OS artefacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Test artefacts
.pytest_cache/
htmlcov/
.coverage

# Temporary files
*.tmp
*.bak
