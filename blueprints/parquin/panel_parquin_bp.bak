# blueprints/parquin/panel_parquin_bp.py
# =============================================================================
# рџљљ PANEL PARQUIN В· COMPATIBLE CON ARQUITECTURA ACTUAL (DISCOVERY)
# =============================================================================
# OBJETIVO:
#   - Mantener la lГіgica actual de KPIs (total, libres, ocupadas)
#   - Asegurar compatibilidad con:
#       В· ConvenciГіn de nombres de blueprints de panel:  panel_xxx_bp
#       В· Descubrimiento automГЎtico vГ­a current_app.url_map (SuperAdmin / discovery)
#
# CГ“MO SE VE DESDE DISCOVERY:
#   - Blueprint name:  "panel_parquin_bp"
#       в†?panel_id = "parquin"
#   - Endpoint registrado:
#       В· funciГіn: panel_parquin
#       В· endpoint completo: "panel_parquin_bp.panel_parquin"
#       в†?discovery lo incluirГЎ dentro del panel "panel_parquin_bp"
#
# RELACIГ“N CON SUPERADMIN:
#   - SuperAdminService.construir_sistema() recorre current_app.url_map
#   - Filtra blueprints cuyo nombre cumple: panel_XXX_bp
#   - Este archivo ya cumple: "panel_parquin_bp" в†?OK
#   - La ruta "/" de este panel aparecerГЎ como un endpoint mГЎs en ese panel
#
# NOTA IMPORTANTE:
#   - Este panel es "clГЎsico": pinta SU propio dashboard de parking
#   - No interfiere con la arquitectura panel/mГіdulo/botones de control_via_publica
#   - Puede convivir sin tocar discovery ni el nuevo sistema
# =============================================================================

from flask import Blueprint, render_template
from db import ejecutar_query, get_connection  # get_connection no se usa aquГ­, pero se mantiene por si se amplГ­a

# =============================================================================
# 1пёЏвѓЈ DEFINICIГ“N DEL BLUEPRINT DE PANEL
# =============================================================================
# ConvenciГіn seguida:
#   - Nombre interno: panel_parquin_bp  вњ?
#   - url_prefix: /panel_parquin       вњ?
#
# Esto provoca que:
#   - La URL del panel sea:        /panel_parquin/
#   - El endpoint de la vista sea: "panel_parquin_bp.panel_parquin"
#   - SuperAdmin/discovery lo detecten como panel "panel_parquin_bp"
# =============================================================================
panel_parquin_bp = Blueprint(
    "panel_parquin_bp",
    __name__,
    url_prefix="/panel_parquin",
)

# =============================================================================
# 2пёЏвѓЈ VISTA PRINCIPAL DEL PANEL PARQUIN
# =============================================================================
# RESPONSABILIDAD:
#   - Calcular KPIs de ocupaciГіn de plazas:
#       В· total_plazas
#       В· plazas_ocupadas
#       В· plazas_libres
#   - Renderizar una plantilla especГ­fica del mГіdulo parquin
#
# BBDD USADA:
#   - Base de datos: parquin_camiones
#   - Tablas:
#       В· tbl_plazas (id, idtbl_usuarios, ...)
#
# COMPATIBILIDAD ARQUITECTURA:
#   - No rompe discovery:
#       В· Es un panel autГіnomo
#       В· No entra en la jerarquГ­a panel/mГіdulo/botones del nuevo sistema
#   - Desde SuperAdmin:
#       В· Se verГЎ como un panel con un Гєnico endpoint "/panel_parquin/"
# =============================================================================
@panel_parquin_bp.route("/")
def panel_parquin():
    """
    PANEL PRINCIPAL DEL PARQUIN DE CAMIONES

    Detalle:
      1. Consulta nГєmero total de plazas.
      2. Consulta cuГЎntas plazas estГЎn ocupadas (idtbl_usuarios NOT NULL).
      3. Calcula plazas libres = total - ocupadas.
      4. EnvГ­a los datos a la plantilla 'parquin/panel_parquin.html'.
    """

    # 1пёЏвѓЈ TOTAL DE PLAZAS
    total_query = ejecutar_query(
        "SELECT COUNT(*) AS total FROM tbl_plazas",
        nombre_bd="parquin_camiones",
    )
    total_plazas = total_query[0]["total"] if total_query else 0

    # 2пёЏвѓЈ PLAZAS OCUPADAS
    ocupadas_query = ejecutar_query(
        "SELECT COUNT(*) AS ocupadas FROM tbl_plazas WHERE idtbl_usuarios IS NOT NULL",
        nombre_bd="parquin_camiones",
    )
    plazas_ocupadas = ocupadas_query[0]["ocupadas"] if ocupadas_query else 0

    # 3пёЏвѓЈ PLAZAS LIBRES (control por si hay datos inconsistentes)
    plazas_libres = max(total_plazas - plazas_ocupadas, 0)

    # 4пёЏвѓЈ RENDER DEL PANEL
    return render_template(
        "parquin/panel_parquin.html",
        total_plazas=total_plazas,
        plazas_libres=plazas_libres,
        plazas_ocupadas=plazas_ocupadas,
    )

# =============================================================================
# 3пёЏвѓЈ NOTAS DE INTEGRACIГ“N
# =============================================================================
# - REGISTRO EN create_app():
#       from blueprints.parquin.panel_parquin_bp import panel_parquin_bp
#       app.register_blueprint(panel_parquin_bp)
#
# - VISIBILIDAD EN SUPERADMIN/DISCOVERY:
#       В· Se detectarГЎ automГЎticamente como panel "panel_parquin_bp"
#       В· No requiere registry, ni cambios en core/discovery.py
#
# - POSIBLE EVOLUCIГ“N FUTURA:
#       В· Si quisieras convertirlo al modelo panel/mГіdulo/botones:
#           В· Este blueprint seguirГ­a siendo el panel
#           В· CrearГ­as mГіdulos tipo modulo_parquin_plazas, modulo_parquin_reservas...
#           В· Los botones btn_plazas_listar, btn_plazas_ocupar, etc.
#       В· Pero con la arquitectura actual, este panel es totalmente vГЎlido.
# =============================================================================
