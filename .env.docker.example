# =============================================================================
# 🐳 TUBBY APP · DOCKER ENVIRONMENT EXAMPLE
# =============================================================================
#
# Copia este archivo a .env antes de correr `docker compose up`.
#
#   cp .env.docker.example .env
#
# IMPORTANTE:
#   - DB_HOST debe ser "mysql" (nombre del servicio en docker-compose.yml).
#     No uses "localhost" dentro de contenedores.
#   - Cambia SECRET_KEY y contraseñas antes de usar en producción.
# =============================================================================

# --- Flask -------------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=cambia-esto-en-produccion

# --- Base de datos (todas las BDs comparten el mismo servidor MySQL) ----------
# IMPORTANTE para Docker: DB_HOST debe ser el nombre del servicio → "mysql"
DB_HOST=mysql
DB_PORT=3306
DB_USER=tubby
DB_PASSWORD=tubby_pass_2024

# --- MySQL root password (solo lo usa el servicio mysql en docker-compose) ---
MYSQL_ROOT_PASSWORD=root_tubby_2024

# --- Puerto del backend -------------------------------------------------------
PORT=5000

# --- Ruta de datos en disco externo (opcional) --------------------------------
# Descomenta y ajusta si quieres guardar los datos en un disco externo.
# Windows:   MYSQL_DATA_DIR=E:/tubby-data/mysql-data
# Linux/Mac: MYSQL_DATA_DIR=/media/user/disco/tubby-data/mysql-data
#
# MYSQL_DATA_DIR=
# MYSQL_INIT_DIR=
# CONTENEDORES_DIR=
